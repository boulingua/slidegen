% beamerthemeboulingua.sty — Beamer theme in the boulingua design language.
% Compile decks with XeLaTeX or LuaLaTeX (fontspec). Self-contained: bundles
% the Source Sans 3 / JetBrains Mono fonts and the boulingua logo.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeboulingua}[2026/07/21 boulingua beamer theme]

\RequirePackage{fontspec}
\RequirePackage{tikz}
\usetikzlibrary{calc}

% ── Palette ─────────────────────────────────────────────────────────────────
% Per-language accent colours (flag-safe; one signature hue per language, none
% of which appears in that language's flag). Default is boulingua blue; call
% e.g. \blgsetlang{daf} after \usetheme to switch the deck to that language.
\definecolor{blgaccent}{HTML}{1A73E8}\definecolor{blgaccenthover}{HTML}{0B57D0}
\definecolor{acc-daf}{HTML}{2370C7}\definecolor{acch-daf}{HTML}{1C5AA0}% German
\definecolor{acc-efl}{HTML}{348D19}\definecolor{acch-efl}{HTML}{266612}% English
\definecolor{acc-fle}{HTML}{588618}\definecolor{acch-fle}{HTML}{3F5F11}% French
\definecolor{acc-afl}{HTML}{4A23C7}\definecolor{acch-afl}{HTML}{3B1CA0}% Arabic
\definecolor{acc-cfl}{HTML}{1C88A0}\definecolor{acch-cfl}{HTML}{156779}% Chinese
\definecolor{acc-ele}{HTML}{2336C7}\definecolor{acch-ele}{HTML}{1C2CA0}% Spanish
\definecolor{acc-gfl}{HTML}{C75D23}\definecolor{acch-gfl}{HTML}{A04B1C}% Greek
\definecolor{acc-ils}{HTML}{8323C7}\definecolor{acch-ils}{HTML}{691CA0}% Italian
\definecolor{acc-jfl}{HTML}{198D78}\definecolor{acch-jfl}{HTML}{126656}% Japanese
\definecolor{acc-lle}{HTML}{C72323}\definecolor{acch-lle}{HTML}{A01C1C}% Latin
\definecolor{acc-nsf}{HTML}{198D4F}\definecolor{acch-nsf}{HTML}{126639}% Norwegian
\definecolor{acc-nvt}{HTML}{198D26}\definecolor{acch-nvt}{HTML}{12661C}% Dutch
\definecolor{acc-pfl}{HTML}{A0791C}\definecolor{acch-pfl}{HTML}{795B15}% Polish
\definecolor{acc-ple}{HTML}{798017}\definecolor{acch-ple}{HTML}{545910}% Portuguese
\definecolor{acc-rki}{HTML}{BC23C7}\definecolor{acch-rki}{HTML}{981CA0}% Russian
\definecolor{acc-tfl}{HTML}{C72396}\definecolor{acch-tfl}{HTML}{A01C79}% Turkish
\definecolor{acc-ufl}{HTML}{C7235D}\definecolor{acch-ufl}{HTML}{A01C4B}% Ukrainian
\newcommand{\blgsetlang}[1]{\colorlet{blgaccent}{acc-#1}\colorlet{blgaccenthover}{acch-#1}}
\definecolor{blgfg}{HTML}{23272B}
\definecolor{blgmuted}{HTML}{6B7280}
\definecolor{blgrule}{HTML}{E4E7EB}
\definecolor{blgsurface}{HTML}{F7F8FA}
\definecolor{blgcefrA}{HTML}{4CAF50}
\definecolor{blgcefrB}{HTML}{1A73E8}
\definecolor{blgcefrC}{HTML}{8E24AA}

% ── Fonts (bundled) ─────────────────────────────────────────────────────────
\setmainfont{SourceSans3}[Path=fonts/, Extension=.ttf,
  UprightFont=*-Regular, BoldFont=*-Bold, FontFace={l}{n}{*-Light}]
\newfontfamily\blgsemibold{SourceSans3-Semibold}[Path=fonts/, Extension=.ttf]
\setmonofont{JetBrainsMono-Regular}[Path=fonts/, Extension=.ttf]
\newfontfamily\blgmarker{PermanentMarker-Regular}[Path=fonts/, Extension=.ttf]

% ── Colours & fonts of beamer elements ──────────────────────────────────────
\setbeamercolor{normal text}{fg=blgfg}
\setbeamercolor{structure}{fg=blgaccent}
\setbeamercolor{frametitle}{fg=blgfg}
\setbeamercolor{title}{fg=blgfg}
\setbeamercolor{itemize item}{fg=blgaccent}
\setbeamercolor{itemize subitem}{fg=blgmuted}
\setbeamercolor{block title}{fg=white,bg=blgaccent}
\setbeamercolor{block body}{bg=blgsurface}
\setbeamerfont{frametitle}{family=\blgsemibold,size=\LARGE}
\setbeamerfont{title}{family=\blgsemibold,size=\huge}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{itemize item}{\small\raise0.5pt\hbox{\textbullet}}
\setbeamertemplate{blocks}[rounded][shadow=false]

% ── Frame title: accent rule underneath ─────────────────────────────────────
\setbeamertemplate{frametitle}{%
  \vskip0.6em\hbox{\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle}%
  \vskip2pt{\color{blgaccent}\rule{\linewidth}{1.4pt}}\vskip0.2em}

% ── Watermark: icon + © author · title, centred at the foot of every slide ──
\setbeamertemplate{background}{%
  \begin{tikzpicture}[remember picture,overlay]
    \node[anchor=south,inner sep=0pt] at ($(current page.south)+(0,3.4mm)$)
      {\raisebox{-1.0mm}{\includegraphics[height=3.8mm]{assets/boulingua-logo.png}}%
       \hspace{1.5mm}{\blgsemibold\scriptsize\color{blgmuted}%
         \textcopyright\ S.~Le Boulanger \ \textbullet\ \inserttitle}};
  \end{tikzpicture}}

% ── Footline: slide number, muted, right ────────────────────────────────────
\setbeamertemplate{footline}{%
  \hfill\usebeamercolor[fg]{blgmuted}\color{blgmuted}\scriptsize
  \insertframenumber\hspace{6mm}\vskip3mm}

% ── Title page ──────────────────────────────────────────────────────────────
% Author + date are carried by the foot watermark, so the title slide shows
% only the title, accent rule and subtitle.
\setbeamertemplate{title page}{%
  \vfill
  {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}
  \vskip4pt{\color{blgaccent}\rule{0.42\linewidth}{2pt}}\par
  \vskip10pt{\color{blgmuted}\large\insertsubtitle\par}
  \vfill}
\endinput
